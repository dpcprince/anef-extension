{
  "manifest_version": 3,
  "name": "anef-statut (fork)",
  "version": "2.7.0.2",
  "version_name": "2.7.0-anefstatut.2",
  "description": "Fork de l'extension ANEF Status — opt-in consent, KPIs corrigés, comparaison sur anef-statut.",
  "author": "anef-statut",
  "default_locale": "fr",
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "clipboardWrite"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "host_permissions": [
    "https://administration-etrangers-en-france.interieur.gouv.fr/*",
    "https://sso.anef.dgef.interieur.gouv.fr/*",
    "https://*.supabase.co/*",
    "https://*.github.io/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://administration-etrangers-en-france.interieur.gouv.fr/*",
        "https://sso.anef.dgef.interieur.gouv.fr/*"
      ],
      "js": ["content/content-script.js"],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": [
        "https://dpcprince.github.io/anef-extension/*",
        "https://letranger-dev.github.io/anef-extension/*"
      ],
      "js": ["content/dashboard-sync.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    },
    "default_title": "ANEF Status Tracker"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["content/injected-script.js", "content/auto-login.js", "lib/forge.min.js"],
      "matches": [
        "https://administration-etrangers-en-france.interieur.gouv.fr/*",
        "https://sso.anef.dgef.interieur.gouv.fr/*"
      ]
    }
  ]
}
